# ============================================================
# 排行榜云端后端配置
# 复制此文件为 .env 并填入实际配置即可启用云端排行榜
# 同时支持 LeanCloud 和 Supabase，配置哪一个就使用哪一个
# 如果两个都配置，优先使用 LEADERBOARD_BACKEND 指定的后端
# ============================================================

# --- 后端选择 ---
# 可选值: leancloud | supabase | local
# 不填或留空则自动检测（优先使用配置了密钥的后端，都没配置则使用 local）
LEADERBOARD_BACKEND=

# ============================================================
# LeanCloud 配置（国内版 / 国际版）
# 注册地址: https://console.leancloud.app/ 或 https://leancloud.cn/
#
# 【数据表约定】无需手动创建，首次写入会自动生成 Leaderboard Class：
#   - levelId   (String)  关卡ID，如 "1"、"2" ... "10"
#   - nickname  (String)  玩家昵称，最大长度 12
#   - score     (Number)  得分，整数
#   - time      (Number)  通关时间（秒），小数精确到毫秒
#   - createdAt (Date)    自动生成的创建时间
#
# 【权限设置】在 LeanCloud 控制台 -> 数据存储 -> Leaderboard -> 权限：
#   - add_fields: 所有用户
#   - create:     所有用户
#   - find:       所有用户
#   - get:        所有用户
#   其他权限（update/delete）建议关闭，防止作弊
# ============================================================
# App ID (必填)
VITE_LEANCLOUD_APP_ID=
# App Key (必填)
VITE_LEANCLOUD_APP_KEY=
# Server URL (国内版必填，国际版留空)
# 示例: https://xxxxxxxx.api.lncldglobal.com
VITE_LEANCLOUD_SERVER_URL=

# ============================================================
# Supabase 配置
# 注册地址: https://supabase.com/
#
# 【数据表约定】请先在 SQL Editor 中执行 src/sql/supabase_leaderboard.sql
#   表名: leaderboard
#   - id         (uuid)         主键，自动生成
#   - level_id   (varchar(16))  关卡ID，加索引
#   - nickname   (varchar(32))  玩家昵称
#   - score      (int4)         得分
#   - time       (float8)       通关时间（秒）
#   - created_at (timestamptz)  创建时间，默认 now()
#
# 【建议索引】加速按关卡查询排行：
#   CREATE INDEX idx_leaderboard_level_score 
#   ON leaderboard (level_id, score DESC, time ASC);
#
# 【RLS 策略】启用行级安全，仅允许 INSERT 和 SELECT：
#   - 所有用户可以 INSERT 新记录
#   - 所有用户可以 SELECT 读取记录
#   禁止 UPDATE 和 DELETE 防止作弊
# ============================================================
# Supabase Project URL (必填)
# 示例: https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=
# Supabase anon public key (必填，注意是 anon key 不是 service_role key)
VITE_SUPABASE_ANON_KEY=
